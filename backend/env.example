# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_TIMEOUT=8

# Credit Scoring Configuration
CREDIT_SCORE_MIN=300
CREDIT_SCORE_MAX=900
HARD_REJECT_THRESHOLD=300

# Rate Configuration
RATE_CEILING=14.0
RATE_FLOOR=10.5
CONCESSION_STEP=0.25

# XGBoost Weights
CIBIL_WEIGHT=0.60
XGBOOST_WEIGHT=0.40

# Session Configuration
SESSION_TTL_HOURS=24

# OCR Configuration
MAX_UPLOAD_BYTES=5242880

# OTP / SMS Configuration
OTP_EXPIRY_MINUTES=5
SMS_PROVIDER=auto
FAST2SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TEXTBELT_API_KEY=
SMS_WEBHOOK_URL=

# Blockchain Configuration
BLOCKCHAIN_DIFFICULTY=4

# Frontend Configuration
FRONTEND_DOMAIN=https://loanease.example.com
